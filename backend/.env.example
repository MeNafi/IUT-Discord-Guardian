# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:menafi@localhost:5432/office_iot?schema=public"

# Server port
PORT=5000

# Office hours (24h format) - used by alert engine
OFFICE_HOURS_START=9
OFFICE_HOURS_END=17

# How long (ms) a device must be continuously ON to trigger a "left on" alert
CONTINUOUS_ON_ALERT_MS=7200000

# Simulator tick interval (ms) - how often simulated rooms randomly change state
SIMULATOR_INTERVAL_MS=8000
